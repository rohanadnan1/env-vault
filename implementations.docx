5. Database Schema
Full Prisma schema. All fields named *Encrypted contain AES-256-GCM ciphertext encoded as base64. Fields named *Iv contain the corresponding 12-byte IV as base64. The server stores no plaintext secret values anywhere.
// prisma/schema.prisma
 
generator client {
  provider = "prisma-client-js"
}
 
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
 
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  // Vault-specific: per-user salt for PBKDF2 key derivation
  vaultSalt     String?   // 32 bytes base64 — generated on first vault setup
  vaultKdfIter  Int       @default(600000) // PBKDF2 iterations
  totpSecret    String?   // TOTP 2FA secret (encrypted)
  lastVaultAt   DateTime? // last time vault was unlocked
 
  sessions      Session[]
  accounts      Account[]
  projects      Project[]
  shares        Share[]   @relation("SharedBy")
  shareAccess   ShareAccess[]
}
 
model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  color       String    @default("#6366F1")
  emoji       String    @default("📁")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  environments Environment[]
  shares       Share[]
}
 
model Environment {
  id        String   @id @default(cuid())
  name      String   // 'development' | 'staging' | 'production' | custom
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
 
  folders   Folder[]
  secrets   Secret[]
 
  @@unique([projectId, name])
}
 
model Folder {
  id            String   @id @default(cuid())
  name          String
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  parentId      String?  // null = root folder
  parent        Folder?  @relation("FolderTree", fields: [parentId], references: [id])
  children      Folder[] @relation("FolderTree")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
 
  secrets       Secret[]
  vaultFiles    VaultFile[]
}
 
model Secret {
  id            String   @id @default(cuid())
  keyName       String   // plaintext — only the name is stored unencrypted
  valueEncrypted String  // AES-256-GCM ciphertext (base64)
  iv            String   // 12-byte IV (base64)
  tags          String[] // ['database', 'third-party'] etc.
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  folderId      String?
  folder        Folder?  @relation(fields: [folderId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
 
  history       SecretHistory[]
 
  @@unique([environmentId, folderId, keyName])
}
 
model SecretHistory {
  id            String   @id @default(cuid())
  secretId      String
  secret        Secret   @relation(fields: [secretId], references: [id], onDelete: Cascade)
  valueEncrypted String
  iv            String
  createdAt     DateTime @default(now())
  // Retain last 5 versions only — enforced in application logic
}
 
model VaultFile {
  id             String  @id @default(cuid())
  name           String  // filename e.g. 'deployment-notes.md'
  contentEncrypted String // full file content, encrypted
  iv             String
  mimeType       String  @default("text/plain")
  folderId       String
  folder         Folder  @relation(fields: [folderId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
 
model Share {
  id             String    @id @default(cuid())
  // What is being shared
  projectId      String?
  project        Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scopeType      String    // 'project' | 'environment' | 'folder' | 'keys'
  scopeId        String    // ID of the shared scope
  // Encrypted bundle (re-encrypted with share key)
  bundleEncrypted String   // JSON array of {keyName, valueEncrypted, iv} — base64
  bundleIv       String
  shareSalt      String    // 32 bytes base64 — for recipient's PBKDF2
  // Access control
  accessToken    String    @unique // cryptographically random, URL-safe
  expiresAt      DateTime?
  singleUse      Boolean   @default(false)
  isRevoked      Boolean   @default(false)
  // Metadata
  sharedById     String
  sharedBy       User      @relation("SharedBy", fields: [sharedById], references: [id])
  recipientEmail String?
  note           String?
  createdAt      DateTime  @default(now())
 
  accessLog      ShareAccess[]
}
 
model ShareAccess {
  id        String   @id @default(cuid())
  shareId   String
  share     Share    @relation(fields: [shareId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  ipAddress String?
  userAgent String?
  accessedAt DateTime @default(now())
}
 
// NextAuth required models
model Account { ... }  // standard NextAuth Account model
model Session { ... }  // standard NextAuth Session model
model VerificationToken { ... }

