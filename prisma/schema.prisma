generator client {
  provider = "prisma-client-js"
}
 
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
 
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  vaultSalt     String?   
  vaultKdfIter  Int       @default(600000) 
  totpSecret    String?   
  lastVaultAt   DateTime? 
 
  sessions      Session[]
  accounts      Account[]
  projects      Project[]
  shares        Share[]   @relation("SharedBy")
  shareAccess   ShareAccess[]
}
 
model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  color       String    @default("#6366F1")
  emoji       String    @default("📁")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  environments Environment[]
  shares       Share[]
}
 
model Environment {
  id        String   @id @default(cuid())
  name      String   
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
 
  folders   Folder[]
  secrets   Secret[]
  vaultFiles VaultFile[]
 
  @@unique([projectId, name])
}
 
model Folder {
  id            String   @id @default(cuid())
  name          String
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  parentId      String?  
  parent        Folder?  @relation("FolderTree", fields: [parentId], references: [id])
  children      Folder[] @relation("FolderTree")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
 
  secrets       Secret[]
  vaultFiles    VaultFile[]
}
 
model Secret {
  id            String   @id @default(cuid())
  keyName       String   
  valueEncrypted String  
  iv            String   
  tags          String   @default("")
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  folderId      String?
  folder        Folder?  @relation(fields: [folderId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
 
  history       SecretHistory[]
 
  @@unique([environmentId, folderId, keyName])
}
 
model SecretHistory {
  id            String   @id @default(cuid())
  secretId      String
  secret        Secret   @relation(fields: [secretId], references: [id], onDelete: Cascade)
  valueEncrypted String
  iv            String
  createdAt     DateTime @default(now())
}
 
model VaultFile {
  id             String  @id @default(cuid())
  name           String  
  contentEncrypted String 
  iv             String
  mimeType       String  @default("text/plain")
  environmentId  String
  environment    Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  folderId       String?
  folder         Folder?  @relation(fields: [folderId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
 
model Share {
  id             String    @id @default(cuid())
  projectId      String?
  project        Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scopeType      String    
  scopeId        String    
  bundleEncrypted String   
  bundleIv       String
  shareSalt      String    
  accessToken    String    @unique 
  expiresAt      DateTime?
  singleUse      Boolean   @default(false)
  isRevoked      Boolean   @default(false)
  sharedById     String
  sharedBy       User      @relation("SharedBy", fields: [sharedById], references: [id])
  recipientEmail String?
  note           String?
  createdAt      DateTime  @default(now())
 
  accessLog      ShareAccess[]
}
 
model ShareAccess {
  id        String   @id @default(cuid())
  shareId   String
  share     Share    @relation(fields: [shareId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  ipAddress String?
  userAgent String?
  accessedAt DateTime @default(now())
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
