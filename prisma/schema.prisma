generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String    @id @default(cuid())
  email                   String    @unique
  emailVerified           DateTime?
  name                    String?
  password                String?
  image                   String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  vaultSalt               String?
  vaultPublicKey          String?   @db.Text
  vaultPublicKeyAlgorithm String?
  vaultKdfIter            Int       @default(600000)
  totpSecret              String?
  lastVaultAt             DateTime?
  sessionVersion          Int       @default(1)

  // Recovery codes
  codesGeneratedAt        DateTime?
  masterPasswordChangedAt DateTime?
  // 2FA vault unlock (encrypted master password stored server-side, gated by TOTP)
  twoFAEncryptedMaster    String?
  twoFAMasterIv           String?
  twoFAUnlockToken        String? // random 32-byte token used to derive AES key

  sessions               Session[]
  accounts               Account[]
  projects               Project[]
  shares                 Share[]                 @relation("SharedBy")
  shareAccess            ShareAccess[]
  recoveryCodes          RecoveryCode[]
  trustedDevices         TrustedDevice[]
  loginChallenges        LoginChallenge[]
  emailVerificationCodes EmailVerificationCode[]
  passwordResetTokens    PasswordResetToken[]

  sentInvitations          ShareInvitation[]  @relation("SentInvitations")
  receivedInvitations      ShareInvitation[]  @relation("ReceivedInvitations")
  shareAccessLogs          ShareAccessLog[]
  shareDownloadLogs        ShareDownloadLog[]
  shareEditRequests        ShareEditRequest[]
  shareComments            ShareComment[]
  spaceMemberships         SpaceMember[]
  receivedSpaceInvitations SpaceInvitation[]  @relation("ReceivedSpaceInvitations")
}

model EmailVerificationCode {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, expiresAt])
  @@index([userId, codeHash])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, expiresAt])
  @@index([userId, tokenHash])
}

model TrustedDevice {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId   String
  label      String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  @@unique([userId, deviceId])
  @@index([userId])
}

model LoginChallenge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId  String
  ipAddress String?
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model RecoveryCode {
  id              String    @id @default(cuid())
  userId          String
  codeHash        String // SHA-256(normalized_code) hex — for fast lookup
  encryptedMaster String // AES-GCM ciphertext of master password, base64
  masterIv        String // AES-GCM IV, base64
  codeSalt        String // HKDF salt, base64
  index           Int // display order 0-29
  usedAt          DateTime?
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, codeHash])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#6366F1")
  emoji       String   @default("📁")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  environments     Environment[]
  shares           Share[]
  shareInvitations ShareInvitation[] @relation("ProjectShareInvitations")
}

model Environment {
  id        String   @id @default(cuid())
  name      String
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  folders    Folder[]
  secrets    Secret[]
  vaultFiles VaultFile[]
  bundles    FileBundle[]

  @@unique([projectId, name])
}

model Folder {
  id            String      @id @default(cuid())
  name          String
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  parentId      String?
  parent        Folder?     @relation("FolderTree", fields: [parentId], references: [id])
  children      Folder[]    @relation("FolderTree")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  secrets    Secret[]
  vaultFiles VaultFile[]
  bundles    FileBundle[]
}

model Secret {
  id             String      @id @default(cuid())
  keyName        String
  valueEncrypted String
  iv             String
  tags           String      @default("")
  environmentId  String
  environment    Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  folderId       String?
  folder         Folder?     @relation(fields: [folderId], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  history SecretHistory[]

  @@unique([environmentId, folderId, keyName])
}

model SecretHistory {
  id                String          @id @default(cuid())
  secretId          String
  secret            Secret          @relation(fields: [secretId], references: [id], onDelete: Cascade)
  valueEncrypted    String
  iv                String
  revisionNumber    Int             @default(1)
  previousHistoryId String?
  previousHistory   SecretHistory?  @relation("SecretHistoryGraph", fields: [previousHistoryId], references: [id], onDelete: SetNull)
  nextVersions      SecretHistory[] @relation("SecretHistoryGraph")
  createdAt         DateTime        @default(now())

  @@index([secretId, createdAt])
}

model VaultFile {
  id               String      @id @default(cuid())
  name             String
  contentEncrypted String
  iv               String
  mimeType         String      @default("text/plain")
  environmentId    String
  environment      Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  folderId         String?
  folder           Folder?     @relation(fields: [folderId], references: [id])
  pinnedAt         DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  history          FileHistory[]
  comments         FileComment[]
  bundleMembership FileBundleMember[]
}

model FileComment {
  id          String    @id @default(cuid())
  fileId      String
  file        VaultFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  content     String // plaintext, or AES-GCM ciphertext (base64) when isEncrypted = true
  iv          String? // AES-GCM IV (base64) — only set when isEncrypted = true
  isEncrypted Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([fileId, createdAt])
}

model FileHistory {
  id                String        @id @default(cuid())
  fileId            String
  file              VaultFile     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  name              String
  contentEncrypted  String
  iv                String
  revisionNumber    Int           @default(1)
  previousHistoryId String?
  previousHistory   FileHistory?  @relation("FileHistoryGraph", fields: [previousHistoryId], references: [id], onDelete: SetNull)
  nextVersions      FileHistory[] @relation("FileHistoryGraph")
  createdAt         DateTime      @default(now())

  @@index([fileId, createdAt])
}

// ── File Bundles ──────────────────────────────────────────────────────────────

enum BundleType {
  EXTENSION // grouped by file extension, e.g. ".js"
  NAME // grouped by shared base name, e.g. "important"
  CUSTOM // user-defined; any files allowed
}

model FileBundle {
  id            String     @id @default(cuid())
  name          String // display name (auto-generated or user-set)
  bundleType    BundleType
  matchRule     String? // ".js" for EXTENSION | "important" for NAME | null for CUSTOM
  folderId      String?
  environmentId String
  sortOrder     Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  members     FileBundleMember[]
  folder      Folder?            @relation(fields: [folderId], references: [id], onDelete: Cascade)
  environment Environment        @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@index([environmentId, folderId])
}

model FileBundleMember {
  fileId   String
  bundleId String
  addedAt  DateTime @default(now())

  file   VaultFile  @relation(fields: [fileId], references: [id], onDelete: Cascade)
  bundle FileBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)

  @@id([fileId, bundleId])
  @@index([bundleId])
}

// ── Private Spaces ───────────────────────────────────────────────────────────

enum MergeResourceType {
  FILE
  SECRET
}

enum MergeRequestStatus {
  PENDING
  APPROVED
  MERGED
  REJECTED
}

enum ElectionStatus {
  ACTIVE
  COMPLETED
}

enum SpaceInvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum SpaceFolderVisibility {
  PERSONAL
  KING
}

enum SpaceFolderDomain {
  FILE
  SECRET
}

enum SpaceWorkspaceResourceMode {
  DRAFT
  FORK
  SYNC
}

model PrivateSpace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       SpaceMember[]
  kingFiles     KingFile[]
  kingSecrets   KingSecret[]
  elections     Election[]
  mergeRequests MergeRequest[]
  invitations   SpaceInvitation[]
  petitions     ReelectionPetition[]
  folders       SpaceFolder[]
  cloneRequests PeerCloneRequest[]
}

model SpaceMember {
  id                String   @id @default(cuid())
  spaceId           String
  userId            String
  encryptedSpaceKey String   @db.Text
  joinedAt          DateTime @default(now())
  isCouncilMember   Boolean  @default(false)

  space PrivateSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  userFiles           UserFile[]
  userSecrets         UserSecret[]
  bundles             SpaceBundle[]
  mergeRequests       MergeRequest[]       @relation("SpaceMemberMergeRequests")
  mergeApprovals      MergeApproval[]
  electionVotes       ElectionVote[]
  reelectionPetitions ReelectionPetition[]
  sentInvitations     SpaceInvitation[]    @relation("SpaceInvitationSender")
  folders             SpaceFolder[]
  folderVotes         SpaceFolderVote[]
  cloneRequestsSent     PeerCloneRequest[]  @relation("CloneRequester")
  cloneRequestsReceived PeerCloneRequest[]  @relation("CloneSource")

  @@unique([spaceId, userId])
  @@index([userId])
}

model KingFile {
  id               String   @id @default(cuid())
  spaceId          String
  name             String
  contentEncrypted String   @db.Text
  iv               String
  folderPath       String   @default("/")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  space         PrivateSpace      @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  history       KingFileHistory[]
  userForks     UserFile[]
  mergeRequests MergeRequest[]

  @@unique([spaceId, folderPath, name])
  @@index([spaceId])
}

model KingSecret {
  id             String   @id @default(cuid())
  spaceId        String
  keyName        String
  valueEncrypted String   @db.Text
  iv             String
  folderPath     String   @default("/")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  space         PrivateSpace        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  history       KingSecretHistory[]
  userForks     UserSecret[]
  mergeRequests MergeRequest[]

  @@unique([spaceId, folderPath, keyName])
  @@index([spaceId])
}

model KingFileHistory {
  id                String            @id @default(cuid())
  kingFileId        String
  kingFile          KingFile          @relation(fields: [kingFileId], references: [id], onDelete: Cascade)
  name              String
  contentEncrypted  String            @db.Text
  iv                String
  folderPath        String            @default("/")
  revisionNumber    Int               @default(1)
  previousHistoryId String?
  previousHistory   KingFileHistory?  @relation("KingFileHistoryGraph", fields: [previousHistoryId], references: [id], onDelete: SetNull)
  nextVersions      KingFileHistory[] @relation("KingFileHistoryGraph")
  createdAt         DateTime          @default(now())

  @@index([kingFileId, createdAt])
}

model KingSecretHistory {
  id                String              @id @default(cuid())
  kingSecretId      String
  kingSecret        KingSecret          @relation(fields: [kingSecretId], references: [id], onDelete: Cascade)
  valueEncrypted    String              @db.Text
  iv                String
  revisionNumber    Int                 @default(1)
  previousHistoryId String?
  previousHistory   KingSecretHistory?  @relation("KingSecretHistoryGraph", fields: [previousHistoryId], references: [id], onDelete: SetNull)
  nextVersions      KingSecretHistory[] @relation("KingSecretHistoryGraph")
  createdAt         DateTime            @default(now())

  @@index([kingSecretId, createdAt])
}

model UserFile {
  id               String   @id @default(cuid())
  kingFileId       String?
  memberId         String
  workspaceMode    SpaceWorkspaceResourceMode @default(DRAFT)
  name             String
  contentEncrypted String   @db.Text
  iv               String
  folderPath       String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  kingFile          KingFile?           @relation(fields: [kingFileId], references: [id], onDelete: Cascade)
  member            SpaceMember         @relation(fields: [memberId], references: [id], onDelete: Cascade)
  bundleMemberships SpaceBundleMember[]

  @@unique([kingFileId, memberId])
  @@unique([memberId, folderPath, name])
  @@index([memberId])
}

model UserSecret {
  id             String   @id @default(cuid())
  kingSecretId   String?
  memberId       String
  workspaceMode  SpaceWorkspaceResourceMode @default(DRAFT)
  keyName        String
  valueEncrypted String   @db.Text
  iv             String
  folderPath     String   @default("/")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  kingSecret KingSecret? @relation(fields: [kingSecretId], references: [id], onDelete: Cascade)
  member     SpaceMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([kingSecretId, memberId])
  @@unique([memberId, folderPath, keyName])
  @@index([memberId])
}

model SpaceFolder {
  id         String                @id @default(cuid())
  spaceId    String
  memberId   String?
  visibility SpaceFolderVisibility
  domain     SpaceFolderDomain
  name       String
  path       String
  parentId   String?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  space    PrivateSpace       @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  member   SpaceMember?       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  parent   SpaceFolder?       @relation("SpaceFolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children SpaceFolder[]      @relation("SpaceFolderTree")
  votes    SpaceFolderVote[]

  @@unique([spaceId, memberId, visibility, domain, path])
  @@index([spaceId, visibility, domain])
  @@index([memberId, visibility, domain])
}

model SpaceFolderVote {
  folderId   String
  memberId   String
  createdAt  DateTime @default(now())

  folder SpaceFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  member SpaceMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@id([folderId, memberId])
  @@index([memberId])
}

model SpaceBundle {
  id         String     @id @default(cuid())
  memberId   String
  name       String
  bundleType BundleType
  matchRule  String?
  sortOrder  Int        @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  member  SpaceMember         @relation(fields: [memberId], references: [id], onDelete: Cascade)
  members SpaceBundleMember[]

  @@index([memberId])
}

model SpaceBundleMember {
  userFileId String
  bundleId   String
  addedAt    DateTime @default(now())

  userFile UserFile    @relation(fields: [userFileId], references: [id], onDelete: Cascade)
  bundle   SpaceBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)

  @@id([userFileId, bundleId])
  @@index([bundleId])
}

model MergeRequest {
  id                 String             @id @default(cuid())
  spaceId            String
  requesterId        String
  resourceType       MergeResourceType
  kingFileId         String?
  kingSecretId       String?
  proposedData       String             @db.Text
  iv                 String
  proposedName       String?
  proposedFolderPath String?
  status             MergeRequestStatus @default(PENDING)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  space      PrivateSpace    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  requester  SpaceMember     @relation("SpaceMemberMergeRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  kingFile   KingFile?       @relation(fields: [kingFileId], references: [id], onDelete: Cascade)
  kingSecret KingSecret?     @relation(fields: [kingSecretId], references: [id], onDelete: Cascade)
  approvals  MergeApproval[]

  @@index([spaceId, status])
  @@index([requesterId])
}

model MergeApproval {
  id         String   @id @default(cuid())
  requestId  String
  memberId   String
  preserveFolderStructure Boolean @default(false)
  approvedAt DateTime @default(now())

  request MergeRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  member  SpaceMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([requestId, memberId])
  @@index([memberId])
}

model Election {
  id          String         @id @default(cuid())
  spaceId     String
  status      ElectionStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  completedAt DateTime?

  space PrivateSpace   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  votes ElectionVote[]

  @@index([spaceId, status])
}

model ElectionVote {
  id           String   @id @default(cuid())
  electionId   String
  voterId      String
  candidate1Id String
  candidate2Id String
  candidate3Id String
  createdAt    DateTime @default(now())

  election Election    @relation(fields: [electionId], references: [id], onDelete: Cascade)
  voter    SpaceMember @relation(fields: [voterId], references: [id], onDelete: Cascade)

  @@unique([electionId, voterId])
  @@index([voterId])
}

model ReelectionPetition {
  id        String   @id @default(cuid())
  spaceId   String
  memberId  String
  createdAt DateTime @default(now())

  space  PrivateSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  member SpaceMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([spaceId, memberId])
  @@index([memberId])
}

model SpaceInvitation {
  id                         String                @id @default(cuid())
  spaceId                    String
  inviterId                  String
  recipientEmail             String
  recipientId                String?
  inviteToken                String                @unique
  encryptedSpaceKey          String?               @db.Text
  encryptedSpaceKeyAlgorithm String?
  status                     SpaceInvitationStatus @default(PENDING)
  expiresAt                  DateTime?
  acceptedAt                 DateTime?
  revokedAt                  DateTime?
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt

  space     PrivateSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  inviter   SpaceMember  @relation("SpaceInvitationSender", fields: [inviterId], references: [id], onDelete: Cascade)
  recipient User?        @relation("ReceivedSpaceInvitations", fields: [recipientId], references: [id], onDelete: SetNull)

  @@index([spaceId, status])
  @@index([recipientEmail])
  @@index([recipientId])
}

model Share {
  id              String    @id @default(cuid())
  projectId       String?
  project         Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scopeType       String
  scopeId         String
  bundleEncrypted String
  bundleIv        String
  shareSalt       String
  accessToken     String    @unique
  expiresAt       DateTime?
  singleUse       Boolean   @default(false)
  isRevoked       Boolean   @default(false)
  sharedById      String
  sharedBy        User      @relation("SharedBy", fields: [sharedById], references: [id])
  recipientEmail  String?
  note            String?
  createdAt       DateTime  @default(now())

  accessLog ShareAccess[]
}

model ShareAccess {
  id         String   @id @default(cuid())
  shareId    String
  share      Share    @relation(fields: [shareId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  ipAddress  String?
  userAgent  String?
  accessedAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Collaborative Share Invitation ──────────────────────────────────
model ShareInvitation {
  id             String  @id @default(cuid())
  ownerId        String
  owner          User    @relation("SentInvitations", fields: [ownerId], references: [id], onDelete: Cascade)
  recipientEmail String
  recipientId    String?
  recipient      User?   @relation("ReceivedInvitations", fields: [recipientId], references: [id])

  resourceType ShareResourceType
  resourceId   String
  projectId    String?
  project      Project?          @relation("ProjectShareInvitations", fields: [projectId], references: [id], onDelete: Cascade)

  permission        SharePermission  @default(READ_ONLY)
  versionMode       ShareVersionMode @default(LATEST)
  specificVersionId String?

  expiresAt DateTime?
  ttlDays   Int?

  inviteToken     String       @unique
  status          InviteStatus @default(PENDING)
  revokedAt       DateTime?
  acceptedAt      DateTime?
  firstAccessedAt DateTime?

  shareEncryptionSalt String
  encryptedShareKey   String
  shareKeyIv          String?

  bundleEncrypted String?
  bundleIv        String?
  encryptionMode  String  @default("collaborative")

  note      String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accessLogs   ShareAccessLog[]
  editRequests ShareEditRequest[]
  comments     ShareComment[]
  downloadLogs ShareDownloadLog[]

  @@index([ownerId])
  @@index([recipientEmail])
  @@index([recipientId])
  @@index([resourceType, resourceId])
  @@index([inviteToken])
}

enum ShareResourceType {
  PROJECT
  ENVIRONMENT
  FOLDER
  FILE
  BUNDLE
  SECRET
}

enum SharePermission {
  READ_ONLY
  COMMENT
  EDIT
}

enum ShareVersionMode {
  LATEST
  SPECIFIC
  ALL
}

enum InviteStatus {
  PENDING
  ACCEPTED
  LEFT
  REVOKED
  EXPIRED
}

// ── Access Logs ─────────────────────────────────────────────────────
model ShareAccessLog {
  id             String          @id @default(cuid())
  invitationId   String
  invitation     ShareInvitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?           @relation(fields: [userId], references: [id])
  action         String
  resourceDetail String?
  ipAddress      String?
  userAgent      String?
  accessedAt     DateTime        @default(now())

  @@index([invitationId, accessedAt])
}

// ── Download Notifications ──────────────────────────────────────────
model ShareDownloadLog {
  id            String          @id @default(cuid())
  invitationId  String
  invitation    ShareInvitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  fileName      String
  fileType      String
  ownerNotified Boolean         @default(false)
  downloadedAt  DateTime        @default(now())

  @@index([invitationId])
}

// ── Edit Requests (PR-like) ─────────────────────────────────────────
model ShareEditRequest {
  id           String          @id @default(cuid())
  invitationId String
  invitation   ShareInvitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  requesterId  String
  requester    User            @relation(fields: [requesterId], references: [id])

  resourceType ShareResourceType
  resourceId   String
  title        String
  description  String?           @db.Text

  proposedEncrypted String  @db.Text
  proposedIv        String
  previousVersionId String?

  status     EditRequestStatus @default(PENDING)
  reviewedAt DateTime?
  reviewNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invitationId, status])
}

enum EditRequestStatus {
  PENDING
  APPROVED
  REJECTED
  MERGED
}

// ── Comments on shared resources ────────────────────────────────────
model ShareComment {
  id           String          @id @default(cuid())
  invitationId String
  invitation   ShareInvitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  authorId     String
  author       User            @relation(fields: [authorId], references: [id])
  content      String          @db.Text
  iv           String?
  isEncrypted  Boolean         @default(true)
  parentId     String?
  parent       ShareComment?   @relation("CommentThread", fields: [parentId], references: [id])
  replies      ShareComment[]  @relation("CommentThread")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([invitationId, createdAt])
}

// ── Peer clone requests (private spaces) ────────────────────────────
enum CloneRequestType {
  STRUCTURE
  CONTENT
}

enum CloneRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model PeerCloneRequest {
  id            String              @id @default(cuid())
  spaceId       String
  space         PrivateSpace        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  requesterId   String
  requester     SpaceMember         @relation("CloneRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  sourceId      String
  source        SpaceMember         @relation("CloneSource", fields: [sourceId], references: [id], onDelete: Cascade)
  type          CloneRequestType    @default(CONTENT)
  status        CloneRequestStatus  @default(PENDING)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([spaceId, status])
  @@index([sourceId, status])
  @@index([requesterId])
}
